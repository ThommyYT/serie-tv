{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "target": "esnext",
    "module": "esnext", 
    "moduleResolution": "bundler", // Ottimo per le Import Maps
    "lib": ["esnext", "dom", "dom.iterable"],
    "typeRoots": ["./node_modules/@types"],
    "types": ["jquery", "bootstrap", "youtube"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "allowUmdGlobalAccess": true, // <--- QUESTA È LA CHIAVE
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}